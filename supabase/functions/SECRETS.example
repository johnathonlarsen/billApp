# Supabase Edge Functions — SANDBOX first
#
# supabase login
# supabase link --project-ref tfpahfhrclojmbfvwasg
#
# Plaid (Sandbox keys from Dashboard → Keys):
# supabase secrets set PLAID_CLIENT_ID=...
# supabase secrets set PLAID_SECRET=...
# supabase secrets set PLAID_ENV=sandbox
# supabase secrets set ANDROID_PACKAGE_NAME=com.family.bankapp
#
# App ↔ Edge Function auth (must match FamilyAppConfig.EDGE_FUNCTION_SECRET):
# supabase secrets set FAMILY_APP_API_SECRET=familybank-edge
#
# Run SQL migrations 001–005 in order (005 = token vault + lock down client writes).
#
# supabase functions deploy plaid-link-token
# supabase functions deploy plaid-exchange
# supabase functions deploy plaid-accounts-sync
# supabase functions deploy plaid-transactions-sync
#
# Compliance notes:
# - Plaid access tokens live in plaid_item_vault (service role only), never on the phone.
# - Plaid secret never in the app; only in Supabase secrets.
# - Supabase free tier includes Edge Functions (500k invocations/mo).
# - Complete Plaid application/company profile before Production.
# - Add a privacy policy URL in Plaid Dashboard before Production (family use still recommended).
